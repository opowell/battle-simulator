{
  "name": "battle-simulator",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "battle-simulator",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=18"
      }
    },
    "apps/classic": {
      "name": "@battle-sim/classic",
      "version": "0.1.0",
      "extraneous": true,
      "dependencies": {
        "@battle-sim/api-client": "*"
      },
      "devDependencies": {
        "vite": "^5.0.0"
      }
    },
    "apps/minimal": {
      "name": "@battle-sim/minimal",
      "version": "0.1.0",
      "extraneous": true,
      "dependencies": {
        "@battle-sim/api-client": "*"
      },
      "devDependencies": {
        "vite": "^5.0.0"
      }
    },
    "apps/modern": {
      "name": "@battle-sim/modern",
      "version": "0.1.0",
      "extraneous": true,
      "dependencies": {
        "@battle-sim/api-client": "*"
      },
      "devDependencies": {
        "vite": "^5.0.0"
      }
    },
    "node_modules/@battle-sim/api-client": {
      "resolved": "packages/api-client",
      "link": true
    },
    "packages/api-client": {
      "name": "@battle-sim/api-client",
      "version": "0.1.0"
    }
  }
}
